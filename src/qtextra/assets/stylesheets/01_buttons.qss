/* ----------------- QPushButton / QLabel type variants ----------------- */

QtPushButton#pick_option_button {
    font-size: {{ increase(font_size, 4) }};
    font-weight: bold;
}

QPushButton[type="error"] {
    color: {{ error }};
}
QPushButton[type="warning"] {
    color: {{ warning }};
}
QPushButton[type="success"] {
    color: {{ success }};
}
