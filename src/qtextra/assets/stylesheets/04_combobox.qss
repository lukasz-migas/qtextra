/* ----------------- QComboBox ------------------ */

QComboBox {
  border-radius: 8px;
  background-color: {{ background }};
  border: 1px solid {{ foreground }};
  min-height: 20px;
  padding: 6px 10px;
  font-size: 13px;
}

QComboBox:hover {
  background-color: {{ primary }};
}

QComboBox:on {
  border: 1.5px solid {{ highlight }};
}

QComboBox:disabled {
  background-color: {{ opacity(background, 75) }};
  border: 1px solid {{ opacity(foreground, 75) }};
  color: {{ opacity(text, 90) }};
}

QWidget[emphasized="true"]  QComboBox {
  background-color: {{ primary }};
  border-color: {{ primary }};
}

QComboBox::drop-down {
  width: 26px;
  border-top-right-radius: 8px;
  border-bottom-right-radius: 8px;
}

QComboBox::down-arrow {
   image: url("theme_{{ id }}://drop_down_50.svg");
   width: 14px;
   height: 14px;
}

QComboBox::down-arrow:on {
  /* when the dropdown is open */
}

QComboBox#filter_combo {
    max-height: 14px;
    background-color: {{ darken(background, 10) }};
    border: 2px solid {{ foreground }};
    border-radius: 2px;
    font-size: {{ increase(font_size, 1) }};
    font-weight: bold;
}

/* ----------------- QListView ------------------ */

QListView {
  /* controls the color of the open dropdown menu */
  background-color: {{ foreground }};
  color: {{ text }};
  border-radius: 4px;
}

QListView:item:hover {
    background-color: {{ lighten(highlight, 20) }};
}

QListView:item:selected {
    background-color: {{ highlight }};
}

QListView::indicator:unchecked {
  image: url("theme_{{ id }}://2d.svg");
}

QListView::indicator:checked {
  image: url("theme_{{ id }}://check.svg");
}

/* ----------------- Custom combobox popup ------------------ */

QScrollArea#combobox_scroll {
    background: {{ background }};
    border: none;
}

QScrollArea#combobox_scroll > QWidget {
    background: {{ background }};
}

QWidget#combobox_inner {
    background: {{ background }};
}

QScrollBar#combobox_scroll:vertical {
    width: 6px;
    background: transparent;
    margin: 0;
}
QScrollBar#combobox_scroll::handle:vertical {
    background: {{ primary }};
    border-radius: 3px;
    min-height: 20px;
}
QScrollBar#combobox_scroll::add-line:vertical,
QScrollBar#combobox_scroll::sub-line:vertical {
    height: 0;
}

_SearchPanel QLineEdit {
    border: 1px solid {{ foreground }};
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 13px;
    color: {{ text }};
    background: {{ background }};
}
_SearchPanel QLineEdit:focus {
    border-color: {{ highlight }};
    background: {{ background }};
}
